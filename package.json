  "scripts": {
    "clean:install": "rm -rf node_modules package-lock.json || true && npm cache clean --force && npm install",
    "start:development": "NODE_ENV=development vite",
    "start:production": "NODE_ENV=production vite",
    "format": "eslint --fix . && npx prettier --write .",
    "prepare": "husky install",
    "build": "NODE_ENV=production vite build",
    "deploy:staging": "npm run build && permaweb-deploy deploy --arns-name ao --ttl-seconds 60 --undername staging --deploy-folder ./dist",
    "deploy:main": "npm run build && permaweb-deploy deploy --arns-name ao --ttl-seconds 60 --deploy-folder ./dist"
  },
