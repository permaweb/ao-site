{
  "name": "-forward-research-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "deploy": "npm run build && bundlr upload-dir ./dist -h https://node1.bundlr.network --wallet ./wallet.json -c arweave --index-file index.html --no-confirmation",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.0.3",
    "@fontsource-variable/roboto-mono": "^5.0.9",
    "@fontsource/dm-sans": "^5.0.12",
    "@fontsource/roboto-mono": "^5.0.8",
    "@rive-app/react-canvas": "^4.7.0",
    "@types/marked": "^6.0.0",
    "arweave": "^1.14.4",
    "marked": "^11.1.1",
    "prismjs": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.16.0",
    "react-type-animation": "^3.1.0",
    "rehype-raw": "^7.0.0",
    "remark-code-blocks": "^2.0.1",
    "remark-gfm": "^4.0.0",
    "typer-js": "^5.5.3",
    "victor": "^1.1.0"
  },
  "devDependencies": {
    "@types/prismjs": "^1.26.3",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.3",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "typescript": "^5.0.2",
    "vite": "^4.4.5"
  }
}
